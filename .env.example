# Google Cloud / BigQuery
GCP_PROJECT_ID=your-gcp-project-id
BIGQUERY_DATASET=uk_market_intelligence
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Job source API
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
ADZUNA_PAGES_PER_QUERY=5
ADZUNA_RESULTS_PER_PAGE=50

# Optional enrichment / LLM providers
OPENAI_API_KEY=
TRUSTPILOT_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_PLACES_API_KEY=

# App config
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
